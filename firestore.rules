rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }
    function isTeacher() {
      return request.auth != null && request.auth.token.role == 'teacher';
    }
    function isStudent() {
      return request.auth != null && request.auth.token.role == 'student';
    }
    function isAuth() {
      return request.auth != null;
    }
    function isTeacherOrAdmin() {
      return isTeacher() || isAdmin();
    }

    match /students/{sid} {
      allow read: if isTeacherOrAdmin()
                  || (isStudent() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    match /rooms/{rid} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /schedule/{eid} {
      allow read: if true;   // 공개 일정표
      allow write: if isAdmin();
    }

    match /buses/{bid} {
      allow read: if isTeacherOrAdmin();
      allow write: if isAdmin();
    }

    match /contacts/{cid} {
      // 클라이언트는 공개여부='Y'만 쿼리하도록 구성, 규칙은 전체 허용
      allow read: if true;
      allow write: if isAdmin();
    }

    match /checkin_sessions/{sid} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /checkins/{cid} {
      allow create: if isAuth();
      allow read:   if isTeacherOrAdmin()
                    || (isStudent() && resource.data.byUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /incidents/{iid} {
      allow create, read: if isTeacherOrAdmin();
      allow update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read:  if request.auth.uid == uid || isTeacherOrAdmin();
      allow write: if request.auth.uid == uid || isAdmin();
    }

    match /settings/global {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // collectionGroup("reads") 쿼리용 wildcard 규칙 — 본인 read만 조회 허용
    match /{path=**}/reads/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
    }

    // ── 채팅방 ─────────────────────────────────────
    match /chat_rooms/{roomId} {
      // 멤버 또는 관리자만 방을 읽을 수 있음
      allow read: if isAuth()
                  && (isAdmin() || request.auth.uid in resource.data.members);

      // 방 생성: 인증 사용자가 본인 uid를 members에 포함시켜야 함
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.members;

      // 방 업데이트:
      //   - 멤버 본인 또는 관리자만 가능
      //   - 단, 학생은 type/이름/카테고리 등은 못 바꾸고 lastMessage·members만 갱신 가능
      allow update: if isAuth()
                    && (isAdmin() || request.auth.uid in resource.data.members);

      // 방 삭제: 관리자만
      allow delete: if isAdmin();

      // ── 채팅 읽음 표시 ──────────────────────────
      // chat_rooms/{roomId}/reads/{uid} : 사용자별 마지막 읽음 시각
      match /reads/{uid} {
        // 본인의 read는 본인이 읽기/쓰기.
        // 교사·관리자는 다른 사용자의 read 상태 모두 읽기 가능 (누가 안 읽었는지 확인).
        allow read: if isAuth()
                    && (request.auth.uid == uid || isTeacherOrAdmin());

        // 본인 read만 작성 가능. 또한 부모 방 멤버여야 함.
        allow write: if isAuth()
                     && request.auth.uid == uid
                     && request.auth.uid in
                        get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.members;
      }

      // ── 채팅 메시지 ─────────────────────────────
      match /messages/{messageId} {
        // 부모 방의 멤버 또는 관리자만 읽기
        allow read: if isAuth()
                    && (isAdmin()
                        || request.auth.uid in
                           get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.members);

        // 메시지 작성:
        //   1) 부모 방의 멤버이고
        //   2) senderUid = 본인이며
        //   3) 학생은 절대 메시지를 보낼 수 없음 (관리자→교사→학생 일방향)
        allow create: if isAuth()
                      && !isStudent()
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.members
                      && request.resource.data.senderUid == request.auth.uid
                      && request.resource.data.senderRole != 'student';

        // 메시지 삭제: 관리자만 (학생 보호 + 운영 책임 명확화)
        allow delete: if isAdmin();

        // 수정 금지 (MVP)
        allow update: if false;
      }
    }
  }
}
